      "$type": "color",
      "$description": "Cards, modals, popovers, dialogs",
      "$value": "{color.neutral.0}",
      "$extensions": {
        "com.figma": {
          "modes": {
            "Light": "{color.neutral.0}",
            "Dark": "{color.neutral.900}"
